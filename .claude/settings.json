      "Bash(vendor/bin/pint*)",
      "Bash(php artisan test*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Read(//C:/xampp/htdocs/PROJECT-BY-CLAUDE/MealHubApi/**)",
